<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Daily Market Brief</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=IBM+Plex+Mono:wght@300;400;500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
:root {
  --gold:#B8965A;--gold-lt:#D4AF7A;--gold-dim:rgba(184,150,90,.15);
  --bg:#07070D;--bg2:#0D0D16;--bg3:#12121C;--bg4:#161620;
  --border:#1E1E2E;--border2:#252535;
  --text:#C8C8D8;--text2:#9898B0;--muted:#525268;
  --green:#3DB87A;--green-dim:rgba(61,184,122,.12);
  --red:#C85454;--red-dim:rgba(200,84,84,.12);
  --blue:#5B7FD4;--blue-dim:rgba(91,127,212,.12);
  --amber:#C89A3D;--amber-dim:rgba(200,154,61,.12);
  --font-serif:'Cormorant Garamond',serif;
  --font-mono:'IBM Plex Mono',monospace;
  --font-sans:'Inter',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-sans);font-size:14px;line-height:1.7;font-weight:300;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");background-size:200px;pointer-events:none;z-index:0;opacity:.5}
::-webkit-scrollbar{width:2px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--gold)}

/* Loading */
#loading{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16px;background:var(--bg);z-index:100;transition:opacity .6s}
#loading.hide{opacity:0;pointer-events:none}
.spin{width:36px;height:36px;border:1px solid var(--border2);border-top-color:var(--gold);border-radius:50%;animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.load-txt{font-family:var(--font-mono);font-size:9px;letter-spacing:3px;color:var(--muted);text-transform:uppercase}
#no-report{display:none;position:fixed;inset:0;align-items:center;justify-content:center;flex-direction:column;gap:12px;background:var(--bg)}
#no-report.show{display:flex}
#app{position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:0 28px 100px;opacity:0;transition:opacity .8s}
#app.visible{opacity:1}

/* Header */
header{padding:48px 0 32px;border-bottom:1px solid var(--border);margin-bottom:40px}
.hdr-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px}
.hdr-class{font-family:var(--font-mono);font-size:8px;letter-spacing:4px;color:var(--gold);text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:8px}
.hdr-class::before{content:'';width:4px;height:4px;background:var(--gold);border-radius:50%}
h1{font-family:var(--font-serif);font-size:48px;font-weight:300;color:#E8E8F4;letter-spacing:-.5px;line-height:1}
h1 em{font-style:italic;color:var(--gold-lt)}
.hdr-date-sub{font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:1px;margin-top:8px}
.hdr-right{text-align:right;display:flex;flex-direction:column;align-items:flex-end;gap:8px}
.hdr-date{font-family:var(--font-serif);font-size:13px;font-style:italic;color:var(--muted)}
.temperature-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:2px;font-family:var(--font-mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:500}
.temp-risk_on{background:var(--green-dim);color:var(--green);border:1px solid rgba(61,184,122,.3)}
.temp-risk_off{background:var(--red-dim);color:var(--red);border:1px solid rgba(200,84,84,.3)}
.temp-neutral{background:var(--amber-dim);color:var(--amber);border:1px solid rgba(200,154,61,.3)}

/* Daily badge */
.daily-badge{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:2px;font-family:var(--font-mono);font-size:8px;letter-spacing:2px;text-transform:uppercase;background:var(--blue-dim);color:var(--blue);border:1px solid rgba(91,127,212,.3)}
.daily-badge::before{content:'●';font-size:6px;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* Nav */
nav{display:flex;gap:1px;flex-wrap:wrap;margin-bottom:48px;background:var(--border);border-radius:2px;overflow:hidden}
nav a{font-family:var(--font-mono);font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);text-decoration:none;padding:8px 14px;background:var(--bg2);transition:all .2s;white-space:nowrap}
nav a:hover{color:var(--gold-lt);background:var(--bg3)}

/* Sections */
section{margin-bottom:72px;opacity:0;transform:translateY(12px);animation:fadeUp .5s ease forwards}
@keyframes fadeUp{to{opacity:1;transform:translateY(0)}}
section:nth-child(1){animation-delay:.06s}section:nth-child(2){animation-delay:.10s}
section:nth-child(3){animation-delay:.14s}section:nth-child(4){animation-delay:.18s}
section:nth-child(5){animation-delay:.22s}section:nth-child(6){animation-delay:.26s}
section:nth-child(7){animation-delay:.30s}section:nth-child(8){animation-delay:.34s}
section:nth-child(9){animation-delay:.38s}

.sec-hdr{display:flex;align-items:baseline;gap:14px;margin-bottom:24px;padding-bottom:12px;border-bottom:1px solid var(--border)}
.sec-num{font-family:var(--font-mono);font-size:9px;color:var(--gold);letter-spacing:2px}
.sec-title{font-family:var(--font-serif);font-size:26px;font-weight:300;color:#D8D8EC;letter-spacing:.3px}
.sec-note{font-family:var(--font-mono);font-size:8px;color:var(--muted);margin-left:auto;letter-spacing:1px}

/* Narrative paragraphs */
.narrative{font-size:13.5px;color:var(--text2);line-height:1.9;border-left:2px solid var(--border);padding-left:16px;margin-bottom:14px;max-width:820px}
.headline-text{font-family:var(--font-serif);font-size:20px;font-weight:600;color:#E0E0EE;margin-bottom:16px;line-height:1.35}

/* Heatmap */
.heatmap-grid{display:grid;gap:2px;margin-bottom:20px}
.heatmap-cell{position:relative;padding:12px 14px;border-radius:2px;overflow:hidden;cursor:default;transition:filter .2s}
.heatmap-cell:hover{filter:brightness(1.15)}
.hm-name{font-family:var(--font-mono);font-size:8.5px;letter-spacing:.5px;text-transform:uppercase;opacity:.85;margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hm-value{font-family:var(--font-mono);font-size:16px;font-weight:500;line-height:1;color:#fff}
.hm-pct{font-family:var(--font-mono);font-size:11px;font-weight:600;margin-top:3px;color:#fff}
.hm-ytd{font-family:var(--font-mono);font-size:8px;opacity:.6;margin-top:2px;color:#fff}
.hm-indices{grid-template-columns:repeat(4,1fr)}
.hm-sectors{grid-template-columns:repeat(4,1fr)}
.hm-forex{grid-template-columns:repeat(3,1fr)}
.hm-commo{grid-template-columns:repeat(4,1fr)}
.hm-strong-up{background:rgba(61,184,122,.45)}
.hm-up{background:rgba(61,184,122,.25)}
.hm-slight-up{background:rgba(61,184,122,.12)}
.hm-flat{background:rgba(82,82,104,.18)}
.hm-slight-dn{background:rgba(200,84,84,.12)}
.hm-dn{background:rgba(200,84,84,.25)}
.hm-strong-dn{background:rgba(200,84,84,.45)}

/* Regions */
.regions{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border)}
.region{background:var(--bg2);padding:20px 22px}
.region-label{font-family:var(--font-mono);font-size:8px;letter-spacing:3px;text-transform:uppercase;margin-bottom:4px}
.region-label.bullish{color:var(--green)}.region-label.bearish{color:var(--red)}.region-label.neutral{color:var(--amber)}
.region-headline{font-family:var(--font-serif);font-size:16px;font-weight:600;color:#D8D8EC;margin-bottom:8px;line-height:1.3}
.region-body{font-size:12.5px;color:var(--muted);line-height:1.75}
.region-kpis{margin-top:10px;display:flex;gap:8px;flex-wrap:wrap}
.kpi{font-family:var(--font-mono);font-size:8px;padding:3px 7px;border-radius:1px}
.kpi.driver{background:var(--blue-dim);color:var(--blue)}
.kpi.risk{background:var(--red-dim);color:var(--red)}
@media(max-width:760px){.regions{grid-template-columns:1fr}}

/* Fixed Income */
.yield-curve-wrap{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);margin-bottom:24px}
.yc-cell{background:var(--bg2);padding:16px 20px}
.yc-label{font-family:var(--font-mono);font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
.yc-value{font-family:var(--font-mono);font-size:24px;color:var(--gold-lt);font-weight:300}
.yc-value span{font-size:13px;color:var(--muted)}
.yc-spread{font-family:var(--font-mono);font-size:11px;margin-top:4px}

/* FX Pairs */
.fx-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);margin-bottom:20px}
.fx-card{background:var(--bg2);padding:16px 18px}
.fx-pair{font-family:var(--font-mono);font-size:10px;letter-spacing:2px;color:var(--gold);margin-bottom:4px}
.fx-rate{font-family:var(--font-mono);font-size:22px;font-weight:300;color:#E8E8F4;margin-bottom:2px}
.fx-chg{font-family:var(--font-mono);font-size:11px;font-weight:600;margin-bottom:8px}
.fx-chg.up{color:var(--green)}.fx-chg.dn{color:var(--red)}.fx-chg.flat{color:var(--muted)}
.fx-levels{display:flex;gap:10px;margin-bottom:8px}
.fx-level{font-family:var(--font-mono);font-size:8px;padding:2px 6px;border-radius:1px}
.fx-level.sup{background:var(--green-dim);color:var(--green)}
.fx-level.res{background:var(--red-dim);color:var(--red)}
.fx-body{font-size:11.5px;color:var(--muted);line-height:1.65}
@media(max-width:760px){.fx-grid{grid-template-columns:1fr}}

/* DXY bar */
.dxy-bar{background:var(--bg2);border:1px solid var(--border);padding:14px 18px;margin-bottom:18px;display:flex;align-items:center;gap:20px}
.dxy-label{font-family:var(--font-mono);font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--gold)}
.dxy-val{font-family:var(--font-mono);font-size:20px;color:#E8E8F4}
.dxy-chg{font-family:var(--font-mono);font-size:11px;font-weight:600}
.dxy-interp{font-size:12px;color:var(--muted);flex:1}

/* Commodities */
.commo-narrative{font-size:13px;color:var(--text2);line-height:1.9;border-left:2px solid var(--border);padding-left:16px;margin-bottom:20px}

/* Positioning */
.positioning-card{background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--amber);padding:22px 24px;margin-bottom:16px}
.vix-display{display:flex;align-items:baseline;gap:10px;margin-bottom:12px}
.vix-label{font-family:var(--font-mono);font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--muted)}
.vix-value{font-family:var(--font-mono);font-size:32px;color:var(--amber);font-weight:300}

/* Email Intelligence */
.email-card{background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--blue);padding:18px 20px;margin-bottom:8px}
.email-story-title{font-family:var(--font-serif);font-size:16px;font-weight:600;color:#D8D8EC;margin-bottom:6px}
.email-story-body{font-size:12.5px;color:var(--muted);line-height:1.75}
.relevance-tag{font-family:var(--font-mono);font-size:8px;letter-spacing:1.5px;text-transform:uppercase;padding:2px 7px;border-radius:1px;margin-bottom:8px;display:inline-block}
.relevance-high{background:var(--green-dim);color:var(--green)}
.relevance-medium{background:var(--amber-dim);color:var(--amber)}
.no-emails{background:var(--bg2);border:1px solid var(--border);padding:20px;font-family:var(--font-mono);font-size:11px;color:var(--muted);text-align:center}

/* Synthesis */
.regime-badge{display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:2px;font-family:var(--font-mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:500;margin-bottom:20px}
.global-view{font-size:14px;color:var(--text);line-height:1.9;margin-bottom:20px}

/* Tomorrow Watch */
.tomorrow-card{background:var(--bg2);border:1px solid var(--border);border-top:2px solid var(--gold);padding:18px 22px;margin-bottom:20px}
.tomorrow-label{font-family:var(--font-mono);font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:10px;display:flex;align-items:center;gap:8px}
.tomorrow-body{font-size:13px;color:var(--text2);line-height:1.85}

/* Strategy */
.strategy-list{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border)}
.strat-card{background:var(--bg2);padding:20px 20px}
.strat-type{margin-bottom:10px}
.strat-type-name{font-family:var(--font-mono);font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:3px}
.strat-conv{font-family:var(--font-mono);font-size:8px;letter-spacing:1px;text-transform:uppercase;margin-bottom:2px}
.strat-tf{font-family:var(--font-mono);font-size:8px;color:var(--muted)}
.strat-rec{margin-bottom:10px}
.strat-rec-title{font-family:var(--font-serif);font-size:15px;font-weight:600;color:#E0E0EE;line-height:1.3}
.strat-rat{font-size:12px;color:var(--muted);line-height:1.7}
@media(max-width:760px){.strategy-list{grid-template-columns:1fr}}

/* Chart container */
.chart-wrap{background:var(--bg2);border:1px solid var(--border);padding:16px;margin-bottom:20px;border-radius:2px}

/* Footer */
footer{border-top:1px solid var(--border);padding:32px 0;display:flex;justify-content:space-between;align-items:center;flex-wrap:gap;gap:12px;margin-top:60px}
.footer-brand{font-family:var(--font-serif);font-size:16px;color:var(--muted)}
.footer-brand em{color:var(--gold);font-style:italic}
.footer-note{font-family:var(--font-mono);font-size:8px;color:var(--muted);letter-spacing:1px;text-align:right}
</style>
</head>
<body>

<div id="loading">
  <div class="spin"></div>
  <div class="load-txt">Loading daily brief…</div>
</div>

<div id="no-report">
  <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:3px;color:var(--gold);text-transform:uppercase">No Report Found</div>
  <div style="font-size:13px;color:var(--muted)">data/latest-daily-report.json not found — run the script first</div>
</div>

<div id="app">
  <header>
    <div class="hdr-top">
      <div>
        <div class="hdr-class">Daily Market Intelligence Brief</div>
        <h1>Daily <em>Market</em> Brief</h1>
        <div class="hdr-date-sub" id="hdr-date-sub"></div>
      </div>
      <div class="hdr-right">
        <div class="daily-badge">Live daily</div>
        <div id="hdr-temp"></div>
        <div class="hdr-date" id="hdr-date"></div>
        <div style="font-family:var(--font-mono);font-size:9px;color:var(--muted)" id="hdr-temp-label"></div>
      </div>
    </div>
    <nav id="nav"></nav>
  </header>

  <div id="content"></div>

  <footer>
    <div class="footer-brand">Daily <em>Market</em> Brief</div>
    <div class="footer-note">Sources: yfinance · FRED · Finnhub · Gmail (Daily Market Watch) · Claude AI<br>Not investment advice · Automated intelligence report</div>
  </footer>
</div>

<script>
// ── Helpers ────────────────────────────────────────────────────────────────
function secHdr(n, title, note='') {
  return `<div class="sec-hdr">
    <span class="sec-num">0${n}</span>
    <span class="sec-title">${title}</span>
    ${note ? `<span class="sec-note">${note}</span>` : ''}
  </div>`;
}

function hmColor(pct) {
  if (pct === null || pct === undefined) return 'hm-flat';
  const v = parseFloat(pct);
  if (v >  2)   return 'hm-strong-up';
  if (v >  0.5) return 'hm-up';
  if (v >  0)   return 'hm-slight-up';
  if (v === 0)  return 'hm-flat';
  if (v > -0.5) return 'hm-slight-dn';
  if (v > -2)   return 'hm-dn';
  return 'hm-strong-dn';
}

function chgHtml(chg) {
  const s = String(chg||'');
  const cls = s.startsWith('+') ? 'up' : s.startsWith('-') ? 'dn' : 'flat';
  const color = cls === 'up' ? 'var(--green)' : cls === 'dn' ? 'var(--red)' : 'var(--muted)';
  return `<span style="color:${color};font-family:var(--font-mono);font-size:11px;font-weight:600">${s}</span>`;
}

function convColor(c) {
  return {high:'var(--green)',medium:'var(--amber)',low:'var(--muted)'}[c] || 'var(--muted)';
}

// ── S1 — Global Overview ───────────────────────────────────────────────────
function renderS1(d) {
  const paras = (d.paragraphs||[]).map(p=>`<p class="narrative">${p}</p>`).join('');
  return `<section id="s1">
    ${secHdr(1, d.title||'Global Market Overview & Sentiment')}
    ${d.headline ? `<div class="headline-text">${d.headline}</div>` : ''}
    ${paras}
  </section>`;
}

// ── S2 — Macro ─────────────────────────────────────────────────────────────
function renderS2(d) {
  const paras = (d.paragraphs||[]).map(p=>`<p class="narrative">${p}</p>`).join('');
  return `<section id="s2">
    ${secHdr(2, d.title||'Macro-Economic Environment')}
    ${paras}
  </section>`;
}

// ── S3 — Equities ──────────────────────────────────────────────────────────
function renderS3(d) {
  // Indices heatmap
  const idxCells = (d.indices||[]).map(i => {
    const chgNum = parseFloat(String(i.change||'0').replace(/[^0-9.\-]/g,''));
    return `<div class="heatmap-cell ${hmColor(chgNum)}">
      <div class="hm-name">${i.name}</div>
      <div class="hm-value">${i.value||'—'}</div>
      <div class="hm-pct">${i.change||'—'}</div>
      <div class="hm-ytd">YTD ${i.ytd||'—'}</div>
    </div>`;
  }).join('');

  // Sector heatmap
  const secCells = (d.sector_performance||[]).map(s => {
    return `<div class="heatmap-cell ${hmColor(s.change_num)}">
      <div class="hm-name">${s.sector}</div>
      <div class="hm-pct" style="font-size:18px">${s.change||'—'}</div>
    </div>`;
  }).join('');

  // Regional analysis
  function region(r, label) {
    if (!r) return '';
    const dir = r.direction||'neutral';
    return `<div class="region">
      <div class="region-label ${dir}">${label} — ${dir.toUpperCase()}</div>
      ${r.headline ? `<div class="region-headline">${r.headline}</div>` : ''}
      <div class="region-body">${r.body||''}</div>
      <div class="region-kpis">
        ${r.key_driver ? `<span class="kpi driver">▶ ${r.key_driver}</span>` : ''}
        ${r.risk ? `<span class="kpi risk">⚠ ${r.risk}</span>` : ''}
      </div>
    </div>`;
  }

  return `<section id="s3">
    ${secHdr(3, d.title||'Equity Markets')}

    <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:10px">Global Indices</div>
    <div class="heatmap-grid hm-indices">${idxCells}</div>

    ${secCells ? `<div style="font-family:var(--font-mono);font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:10px">Sector Performance</div>
    <div class="heatmap-grid hm-sectors">${secCells}</div>` : ''}

    <div class="regions">
      ${region(d.us,'United States')}
      ${region(d.europe,'Europe')}
      ${region(d.asia,'Asia')}
    </div>
  </section>`;
}

// ── S4 — Fixed Income ──────────────────────────────────────────────────────
function renderS4(d) {
  const yc = d.yield_curve||{};
  const spreadColor = yc.spread_2_10 && String(yc.spread_2_10).startsWith('-') ? 'var(--red)' : 'var(--green)';

  return `<section id="s4">
    ${secHdr(4, d.title||'Fixed Income & Rates')}
    <div class="yield-curve-wrap">
      <div class="yc-cell">
        <div class="yc-label">US 2Y Treasury</div>
        <div class="yc-value">${yc.us_2y||'—'}<span>%</span></div>
      </div>
      <div class="yc-cell">
        <div class="yc-label">US 10Y Treasury</div>
        <div class="yc-value">${yc.us_10y||'—'}<span>%</span></div>
      </div>
      <div class="yc-cell">
        <div class="yc-label">US 30Y Treasury</div>
        <div class="yc-value">${yc.us_30y||'—'}<span>%</span></div>
      </div>
      <div class="yc-cell">
        <div class="yc-label">2s10s Spread</div>
        <div class="yc-value" style="color:${spreadColor}">${yc.spread_2_10||'—'}</div>
        ${yc.interpretation ? `<div class="yc-spread" style="color:var(--muted);font-size:11px;margin-top:6px">${yc.interpretation.substring(0,200)}…</div>` : ''}
      </div>
    </div>
    <p class="narrative">${d.narrative||''}</p>
  </section>`;
}

// ── S5 — Forex ─────────────────────────────────────────────────────────────
function renderS5(d) {
  const dxy = d.dxy||{};
  const dxyChgCls = String(dxy.change||'').startsWith('+') ? 'up' : 'dn';

  const pairs = (d.pairs||[]).map(p => {
    const chgCls = p.direction === 'up' ? 'up' : p.direction === 'down' ? 'dn' : 'flat';
    return `<div class="fx-card">
      <div class="fx-pair">${p.pair}</div>
      <div class="fx-rate">${p.value||'—'}</div>
      <div class="fx-chg ${chgCls}">${p.change||'—'}</div>
      <div class="fx-levels">
        ${p.support ? `<span class="fx-level sup">SUP ${p.support}</span>` : ''}
        ${p.resistance ? `<span class="fx-level res">RES ${p.resistance}</span>` : ''}
      </div>
      <div class="fx-body">${(p.analysis||'').substring(0,200)}</div>
    </div>`;
  }).join('');

  return `<section id="s5">
    ${secHdr(5, d.title||'Foreign Exchange')}
    <div class="dxy-bar">
      <div class="dxy-label">DXY</div>
      <div class="dxy-val">${dxy.value||'—'}</div>
      <div class="dxy-chg" style="color:${dxyChgCls==='up'?'var(--red)':'var(--green)'}">${dxy.change||''}</div>
      <div class="dxy-interp">${(dxy.interpretation||'').substring(0,200)}</div>
    </div>
    <p class="narrative" style="margin-bottom:20px">${d.narrative||''}</p>
    <div class="fx-grid">${pairs}</div>
  </section>`;
}

// ── S6 — Commodities ───────────────────────────────────────────────────────
function renderS6(d) {
  const cells = (d.items||[]).map(it => {
    const chgNum = it.change_num !== undefined ? it.change_num : parseFloat(String(it.change||'0').replace(/[^0-9.\-]/g,''));
    return `<div class="heatmap-cell ${hmColor(chgNum)}" style="padding:14px">
      <div class="hm-name">${it.name} <span style="font-size:7px;opacity:.6">${it.unit||''}</span></div>
      <div class="hm-value" style="font-size:18px">${it.value||'—'}</div>
      <div class="hm-pct">${it.change||'—'}</div>
      ${it.analysis ? `<div style="font-size:9px;opacity:.7;margin-top:6px;line-height:1.5;color:#fff">${(it.analysis||'').substring(0,80)}…</div>` : ''}
    </div>`;
  }).join('');

  return `<section id="s6">
    ${secHdr(6, d.title||'Commodities & Alternative Assets')}
    <p class="commo-narrative">${d.narrative||''}</p>
    <div class="heatmap-grid hm-commo">${cells}</div>
  </section>`;
}

// ── S7 — Positioning ───────────────────────────────────────────────────────
function renderS7(d) {
  // Try to extract VIX value from narrative
  const vixMatch = (d.narrative||'').match(/VIX[^0-9]*(\d+\.?\d*)/i);
  const vixVal = vixMatch ? vixMatch[1] : null;

  return `<section id="s7">
    ${secHdr(7, d.title||'Market Positioning & Sentiment')}
    <div class="positioning-card">
      ${vixVal ? `<div class="vix-display"><span class="vix-label">VIX</span><span class="vix-value">${vixVal}</span></div>` : ''}
      <p style="font-size:13.5px;color:var(--text2);line-height:1.9">${d.narrative||''}</p>
    </div>
  </section>`;
}

// ── S8 — Email Intelligence ────────────────────────────────────────────────
function renderS8(d) {
  const stories = (d.key_stories||[]);
  const storiesHtml = stories.length ? stories.map(s => `
    <div class="email-card">
      <div class="relevance-tag relevance-${s.relevance||'medium'}">${(s.relevance||'medium').toUpperCase()} RELEVANCE</div>
      <div class="email-story-title">${s.title||''}</div>
      <div class="email-story-body">${s.body||''}</div>
    </div>`).join('') : '<div class="no-emails">📭 No email intelligence for today — label "Daily Market Watch" had no messages in the last 24h</div>';

  return `<section id="s8">
    ${secHdr(8, d.title||'Email Intelligence — Daily Market Watch', 'Last 24h · Label: Daily Market Watch')}
    <p class="narrative" style="margin-bottom:16px">${d.summary||''}</p>
    ${storiesHtml}
  </section>`;
}

// ── S9 — Synthesis ─────────────────────────────────────────────────────────
function renderS9(d) {
  const regime = d.regime||'neutral';
  const rLabels = {risk_on:'RISK ON ▲',risk_off:'RISK OFF ▼',transition:'TRANSITION',stagflation:'STAGFLATION ⚠',goldilocks:'GOLDILOCKS ◆'};
  const rColor  = {risk_on:'var(--green)',risk_off:'var(--red)',stagflation:'var(--red)',goldilocks:'var(--green)',transition:'var(--amber)'}[regime]||'var(--amber)';

  const strats = (d.strategy||[]).map(s => `
    <div class="strat-card">
      <div class="strat-type">
        <div class="strat-type-name">${s.type||''}</div>
        <div class="strat-conv" style="color:${convColor(s.conviction)}">${(s.conviction||'').toUpperCase()}</div>
        <div class="strat-tf">${s.timeframe||''}</div>
      </div>
      <div class="strat-rec"><div class="strat-rec-title">${s.recommendation||''}</div></div>
      <div class="strat-rat">${s.rationale||''}</div>
    </div>`).join('');

  return `<section id="s9">
    ${secHdr(9, d.title||'Daily Synthesis & Outlook')}
    <div class="regime-badge" style="background:${rColor}1a;color:${rColor};border:1px solid ${rColor}44">${rLabels[regime]||regime.toUpperCase()}</div>
    <p class="global-view">${d.global_view||''}</p>

    ${d.tomorrow_watch ? `<div class="tomorrow-card">
      <div class="tomorrow-label">📅 Tomorrow — Key Events & Data to Watch</div>
      <div class="tomorrow-body">${d.tomorrow_watch}</div>
    </div>` : ''}

    <div style="font-family:var(--font-mono);font-size:9px;color:var(--gold);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px">Daily Strategies</div>
    <div class="strategy-list">${strats}</div>
  </section>`;
}

// ── Chart: sector bar chart ────────────────────────────────────────────────
function renderSectorChart(sectors) {
  if (!sectors || !sectors.length) return '';
  const id = 'sectorChart';
  return `<div class="chart-wrap" style="margin-top:20px">
    <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:12px">Sector Performance — Today</div>
    <canvas id="${id}" height="80"></canvas>
  </div>`;
}

function initSectorChart(sectors) {
  const canvas = document.getElementById('sectorChart');
  if (!canvas || !sectors || !sectors.length) return;
  new Chart(canvas, {
    type: 'bar',
    data: {
      labels: sectors.map(s => s.sector),
      datasets: [{
        data: sectors.map(s => s.change_num||0),
        backgroundColor: sectors.map(s => (s.change_num||0) >= 0 ? 'rgba(61,184,122,0.6)' : 'rgba(200,84,84,0.6)'),
        borderColor: sectors.map(s => (s.change_num||0) >= 0 ? '#3DB87A' : '#C85454'),
        borderWidth: 1,
        borderRadius: 2,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { color: '#525268', font: { family: "'IBM Plex Mono'", size: 9 } }, grid: { color: '#1E1E2E' } },
        y: { ticks: { color: '#525268', font: { family: "'IBM Plex Mono'", size: 9 }, callback: v => v+'%' }, grid: { color: '#1E1E2E' } }
      }
    }
  });
}

// ── INIT ───────────────────────────────────────────────────────────────────
async function init() {
  try {
    const resp = await fetch('./data/latest-daily-report.json?v=' + Date.now());
    if (!resp.ok) throw new Error('No report found');
    const wrapper = await resp.json();

    // Support both wrapped {report: ...} and direct report
    const r = wrapper.report || wrapper;

    // Header
    const temp = r.market_temperature || 'neutral';
    const tempLabels = {risk_on:'RISK ON ▲', risk_off:'RISK OFF ▼', neutral:'NEUTRAL ◆'};
    document.getElementById('hdr-date-sub').textContent = r.date || '';
    document.getElementById('hdr-date').textContent     = 'Generated ' + (r.generated_at||'').substring(0,16);
    document.getElementById('hdr-temp-label').textContent = r.market_temperature_label||'';
    document.getElementById('hdr-temp').innerHTML =
      `<div class="temperature-badge temp-${temp}">${tempLabels[temp]||temp}</div>`;

    // Nav links
    const navItems = [
      {id:'s1', label:'Overview'},
      {id:'s2', label:'Macro'},
      {id:'s3', label:'Equities'},
      {id:'s4', label:'Fixed Income'},
      {id:'s5', label:'Forex'},
      {id:'s6', label:'Commodities'},
      {id:'s7', label:'Positioning'},
      {id:'s8', label:'Email Intel'},
      {id:'s9', label:'Synthesis'},
    ];
    document.getElementById('nav').innerHTML = navItems
      .map(n => `<a href="#${n.id}">${n.label}</a>`).join('');

    // Sector chart placeholder (inserted inside S3)
    const sectors = (r.section3_equities||{}).sector_performance||[];

    // Render all sections
    document.getElementById('content').innerHTML =
      renderS1(r.section1_overview||{}) +
      renderS2(r.section2_macro||{}) +
      renderS3(r.section3_equities||{}) +
      renderSectorChart(sectors) +
      renderS4(r.section4_fixed_income||{}) +
      renderS5(r.section5_forex||{}) +
      renderS6(r.section6_commodities||{}) +
      renderS7(r.section7_positioning||{}) +
      renderS8(r.section8_email_intelligence||{}) +
      renderS9(r.section9_synthesis||{});

    // Init chart after DOM render
    setTimeout(() => initSectorChart(sectors), 100);

    document.getElementById('loading').classList.add('hide');
    setTimeout(() => document.getElementById('app').classList.add('visible'), 80);

  } catch(e) {
    console.error(e);
    document.getElementById('loading').classList.add('hide');
    document.getElementById('no-report').classList.add('show');
  }
}
init();
</script>
</body>
</html>
